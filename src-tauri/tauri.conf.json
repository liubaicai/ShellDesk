{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ShellDesk",
  "version": "1.0.0",
  "identifier": "com.shelldesk.app",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ShellDesk",
        "width": 1260,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "backgroundColor": "#0e131c",
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "liubaicai",
    "category": "DeveloperTool",
    "copyright": "GPL-3.0-only",
    "shortDescription": "ShellDesk",
    "longDescription": "A GUI SSH client and remote desktop toolbox.",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../src/assets/images/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
