{
  "name": "ShellDesk",
  "productName": "ShellDesk",
  "version": "0.1.0",
  "private": true,
  "description": "Blank Electron shell for a GUI SSH client.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http-get://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc --noEmit && vite build",
    "release:dir": "pnpm build && electron-builder --dir",
    "release": "pnpm build && electron-builder --win nsis --publish never",
    "start": "electron .",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "com.shelldesk.app",
    "productName": "ShellDesk",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/assets/images/icon.png",
        "to": "app-icon.png"
      }
    ],
    "win": {
      "icon": "src/assets/images/icon.png",
      "signAndEditExecutable": true,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.10.1",
    "mysql2": "^3.22.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "sass": "^1.99.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "wait-on": "^9.0.3"
  }
}
